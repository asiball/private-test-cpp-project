FROM ubuntu:24.04

RUN apt-get update && apt-get install -y --no-install-recommends \
        g++ \
        cmake \
        make \
        doxygen \
        graphviz \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

CMD ["bash", "-c", "\
    rm -f build/CMakeCache.txt && \
    cmake -S . -B build -DCMAKE_BUILD_TYPE=Release && \
    cmake --build build -j$(nproc) && \
    mkdir -p docs/doxygen && \
    doxygen Doxyfile \
"]
